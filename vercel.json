{
  "builds": [
    {
      "src": "api/playlist.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/playlist.m3u8",
      "dest": "/api/playlist.py"
    },
    {
      "src": "/api/playlist",
      "dest": "/api/playlist.py"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
